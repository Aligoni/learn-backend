# ---------------------------------------------------------------------------
# Local environment for `learn-backend`
# ---------------------------------------------------------------------------
# Copy this file to `.env` at the project root (`.env` is gitignored).
# Then run: `yarn install` and `yarn start` (or `yarn start:dev` while developing).
# ---------------------------------------------------------------------------

# HTTP port for the Nest app (default 3000 if omitted).
PORT=3000

# Single shared secret used to sign and verify JWT access tokens.
# Generate a long random string for real use; never commit real secrets.
JWT_SECRET=change-me-to-a-long-random-string-in-your-local-env-file

# JWT lifetime passed to jsonwebtoken `expiresIn` (e.g. "7d", "24h", "3600").
JWT_EXPIRES_IN=7d

# SQLite database file path (relative to current working directory when you start the app).
# Parent directories are created automatically if missing (except for `:memory:`).
# Example keeps the DB under ./data so you can gitignore the whole folder.
DATABASE_PATH=./data/dev.sqlite

# Use `development` locally so TypeORM can synchronize schema for learning.
# Set to `production` when you deploy and use migrations instead of synchronize.
NODE_ENV=development

# ---------------------------------------------------------------------------
# Swagger UI is served at: http://localhost:<PORT>/api
# (with default PORT=3000: http://localhost:3000/api)
# ---------------------------------------------------------------------------
